{
  "name": "nunopi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && ELECTRON_START_URL=http://localhost:3000 electron electron/main.cjs\"",
    "electron:build": "next build && node scripts/copy-standalone-assets.mjs",
    "electron:prod": "npm run electron:build && electron electron/main.cjs",
    "electron:dist:dir": "npm run electron:build && electron-builder --dir --config electron-builder.yml",
    "electron:dist": "npm run electron:build && electron-builder --config electron-builder.yml",
    "postelectron:dist:dir": "npm rebuild better-sqlite3",
    "postelectron:dist": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@sna-sdk/client": "0.17.2",
    "@sna-sdk/core": "0.17.2",
    "@tabler/icons-react": "^3.44.0",
    "better-sqlite3": "^12.11.1",
    "langfuse": "^3.38.20",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.cjs"
}
